bun.lockb

# Demo credentials — gitignored so LGE-issued API keys are never committed.
# Copy .env.demo.example to .env.demo and fill in the real values.
# scripts/run-electron.mjs auto-loads this file on `bun run start`.
.env.demo
.env.demo.local

# Generated by `bun run build:icons` every build — keeping it tracked
# inflates every developer's git stash on context switch since the
# regenerated bytes never match the committed copy exactly.
build/icon.png
