# syntax=docker/dockerfile:1.7

ARG BUN_IMAGE=oven/bun:1.3.14@sha256:e10577f0db68676a7024391c6e5cb4b879ebd17188ab750cf10024a6d700e5c4
ARG PYTHON_IMAGE=python:3.12.13-slim-bookworm@sha256:d50fb7611f86d04a3b0471b46d7557818d88983fc3136726336b2a4c657aa30b

FROM ${BUN_IMAGE} AS dependencies
ARG SDK_SHA
USER root
WORKDIR /deps
COPY --from=candidate package.json bun.lock ./
COPY --from=control \
  test/control/marketplace-e2e/verify-bun-dependency-inputs.mjs \
  /trusted/verify-bun-dependency-inputs.mjs
RUN --network=none bun /trusted/verify-bun-dependency-inputs.mjs \
      --mode ep \
      --package package.json \
      --lock bun.lock \
      --sdk-sha "${SDK_SHA}"
RUN --mount=type=cache,id=lvis-m4-ep-candidate-bun,target=/root/.bun/install/cache \
    bun install \
      --frozen-lockfile \
      --ignore-scripts \
      --registry=https://registry.npmjs.org

FROM ${BUN_IMAGE} AS candidate-build
USER root
WORKDIR /candidate/ep
COPY --from=candidate . .
COPY --from=dependencies /deps/node_modules ./node_modules
# Candidate build scripts receive no network and no trusted harness or sibling
# repository context. No process from this RUN survives the BuildKit stage.
RUN --network=none bun run build \
    && test -s dist/hostPlugin.js \
    && test -s dist/ui/lge-control.js
FROM ${PYTHON_IMAGE} AS packager
WORKDIR /candidate/ep
COPY --from=candidate-build /candidate/ep/plugin.json ./plugin.json
COPY --from=candidate-build /candidate/ep/dist ./dist
COPY --from=candidate-build /candidate/ep/skills ./skills
COPY --from=control test/control/marketplace-e2e/package-ep.py /trusted/package-ep.py
RUN --network=none mkdir -p /bundle \
    && python3 /trusted/package-ep.py \
    && test -s /bundle/lvis-plugin-ep.zip

FROM scratch AS artifact
COPY --from=packager /bundle/lvis-plugin-ep.zip /bundle/lvis-plugin-ep.zip
