# syntax=docker/dockerfile:1.7

ARG BUN_IMAGE=oven/bun:1.3.14@sha256:e10577f0db68676a7024391c6e5cb4b879ebd17188ab750cf10024a6d700e5c4

FROM ${BUN_IMAGE}
ARG MODE
ARG SDK_SHA
USER root
RUN --network=none mkdir -p /deps /trusted \
    && chown 1000:1000 /deps
COPY --from=input --chown=1000:1000 package.json bun.lock /deps/
COPY --from=control --chown=1000:1000 \
  test/control/marketplace-e2e/verify-bun-dependency-inputs.mjs \
  /trusted/verify-bun-dependency-inputs.mjs
RUN --network=none bun /trusted/verify-bun-dependency-inputs.mjs \
      --mode "${MODE}" \
      --package /deps/package.json \
      --lock /deps/bun.lock \
      ${SDK_SHA:+--sdk-sha "${SDK_SHA}"} \
    && chmod -R a-w /trusted /deps/package.json /deps/bun.lock
USER 1000:1000
WORKDIR /deps
ENV HOME=/deps \
    BUN_INSTALL_CACHE_DIR=/deps/.cache/bun
ENTRYPOINT ["bun", "install", "--frozen-lockfile", "--ignore-scripts", "--registry=https://registry.npmjs.org"]
