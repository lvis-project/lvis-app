# syntax=docker/dockerfile:1.7

ARG BUN_IMAGE=oven/bun:1.3.14@sha256:e10577f0db68676a7024391c6e5cb4b879ebd17188ab750cf10024a6d700e5c4

FROM ${BUN_IMAGE}
USER root
RUN mkdir -p /artifacts \
    && chown 10001:10001 /artifacts \
    && chmod 0500 /artifacts
COPY --from=artifacts --chown=10001:10001 --chmod=0400 \
  lvis-plugin-ep.zip sdk-evidence.json /artifacts/
USER 10001:10001
ENTRYPOINT ["true"]
