# .env.demo.example — internal demo credentials template
#
# Copy this file to .env.demo (gitignored) and fill in the real values.
# scripts/run-electron.mjs loads .env.demo automatically on `bun run start`
# so you do NOT need to `source` it manually.
#
# NEVER commit .env.demo — it contains a demo API key.

# Vendor the Login chip activates. azure-foundry is the intranet demo target.
LVIS_DEMO_VENDOR=azure-foundry

# Azure AI Foundry credentials (obtain from the demo owner).
#
# BASEURL must be the deployment-based Foundry endpoint —
# `https://<resource>.openai.azure.com/openai/deployments/<deployment>/`
# — NOT the OpenAI-compatible `/openai/v1/` alias. The Vercel AI SDK
# adapter appends `chat/completions?api-version=...` to this base. The
# OpenAI-compatible alias path silently 404s the chat call. See
# `src/permissions/reviewer/provider-adapters.ts` Foundry endpoint
# shape and `validateFoundryEndpoint`.
LVIS_DEMO_KEY_AZURE_FOUNDRY=<paste-api-key-here>
LVIS_DEMO_BASEURL_AZURE_FOUNDRY=https://aif-swc-axpg-hq-hckt19.openai.azure.com/openai/deployments/gpt-5.4-mini/
LVIS_DEMO_MODEL_AZURE_FOUNDRY=gpt-5.4-mini

# Host resolver — maps Azure Foundry hostnames to intranet IPs inside
# Electron only (no /etc/hosts mutation). Leave blank or omit if your
# machine can resolve these via DNS.
LVIS_DEMO_HOST_MAP=aif-swc-axpg-hq-hckt19.cognitiveservices.azure.com=10.182.192.174,aif-swc-axpg-hq-hckt19.openai.azure.com=10.182.192.175,aif-swc-axpg-hq-hckt19.services.ai.azure.com=10.182.192.176
