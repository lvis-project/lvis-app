# .env.demo.example — activation payload template (developer reference)
#
# Copy this file to .env.demo (gitignored) and fill in the values your team or
# company delivered with the activation key. scripts/run-electron.mjs loads
# .env.demo automatically on `bun run start`, so you do NOT `source` it manually.
#
# NEVER commit .env.demo — it carries a private API key + intranet topology.
# Use ONLY placeholder values in this committed template; the real endpoints,
# hosts, and subnet ship inside the encrypted activation key, not in source.

# Vendor the activation backend selects. azure-foundry is the intranet target.
LVIS_DEMO_VENDOR=azure-foundry

# Vendor credentials (provided with your activation key).
LVIS_DEMO_KEY_AZURE_FOUNDRY=<paste-api-key-here>
# Azure OpenAI deployment endpoint. Keep api-version in the URL; the app
# extracts it and sends it as the required query param on chat/completions.
LVIS_DEMO_ENDPOINT_AZURE_FOUNDRY=https://<your-resource>.openai.azure.com/openai/deployments/<deployment>/?api-version=<api-version>
LVIS_DEMO_MODEL_AZURE_FOUNDRY=<model-id>

# Host resolver — maps the endpoint hostnames to intranet IPs inside Electron
# only (no /etc/hosts mutation). Leave blank or omit if your machine resolves
# these via DNS. Use the real hostnames + IPs from your activation key.
LVIS_DEMO_HOST_MAP=<your-resource>.cognitiveservices.azure.com=10.0.0.10,<your-resource>.openai.azure.com=10.0.0.11,<your-resource>.services.ai.azure.com=10.0.0.12

# Optional: narrow the allowed host-map target subnet to your intranet range
# (comma-separated CIDRs). MUST be a strict subset of the private (RFC1918)
# ranges — public/non-private CIDRs are rejected. When omitted, targets are
# confined to the generic RFC1918 ranges. Set this to the exact subnet from your
# activation key so the source tree never carries your organisation's topology.
LVIS_DEMO_HOST_SUBNET=10.0.0.0/24
