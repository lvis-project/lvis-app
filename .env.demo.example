# .env.demo.example — LGE internal demo credentials template
#
# Copy this file to .env.demo (gitignored) and fill in the real values.
# scripts/run-electron.mjs loads .env.demo automatically on `bun run start`
# so you do NOT need to `source` it manually.
#
# NEVER commit .env.demo — it contains an LGE-issued API key.

# Master gate — must be "1" for the mockup login IPC handler to register
# in packaged builds. Dev builds (bun run start) always register.
LVIS_DEMO_ENABLED=1

# Vendor the Login chip activates. azure-foundry is the LGE intranet demo target.
LVIS_DEMO_VENDOR=azure-foundry

# Azure AI Foundry credentials (LGE-issued — obtain from the demo owner)
LVIS_DEMO_KEY_AZURE_FOUNDRY=<paste-api-key-here>
LVIS_DEMO_BASEURL_AZURE_FOUNDRY=https://aif-swc-axpg-hq-hckt19.openai.azure.com/openai/v1/
LVIS_DEMO_MODEL_AZURE_FOUNDRY=gpt-4o

# Host resolver — maps Azure Foundry hostnames to LGE intranet IPs inside
# Electron only (no /etc/hosts mutation). Required when running on the LGE
# intranet. Leave blank or omit if your machine can resolve these via DNS.
LVIS_DEMO_HOST_MAP=aif-swc-axpg-hq-hckt19.cognitiveservices.azure.com=10.182.192.174,aif-swc-axpg-hq-hckt19.openai.azure.com=10.182.192.175,aif-swc-axpg-hq-hckt19.services.ai.azure.com=10.182.192.176
