{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "types": [
      "node"
    ],
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": "."
  },
  "include": [
    "src",
    "scripts"
  ],
  "exclude": [
    "src/**/__tests__/**",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/preload.ts",
    "src/preload.cjs.ts",
    "src/renderer.tsx"
  ]
}
