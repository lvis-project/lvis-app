{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://lvis.lge.com/schemas/plugin.schema.json",
  "title": "LVIS Plugin Manifest",
  "description": "Validates plugin.json manifest files for LVIS plugins (§9)",
  "type": "object",
  "required": ["id", "name", "version", "entry", "tools"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "description": "Plugin unique identifier (dot-format recommended)",
      "pattern": "^[a-zA-Z][a-zA-Z0-9._-]*$",
      "minLength": 3,
      "maxLength": 128
    },
    "name": { "type": "string", "minLength": 1 },
    "description": {
      "type": "string",
      "maxLength": 280,
      "description": "Short human-readable summary used in the inactive-plugin catalog LLM sees in the system prompt."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[\\w.]+)?(\\+[\\w.]+)?$",
      "description": "Anchored semver (MAJOR.MINOR.PATCH with optional -prerelease / +build metadata)"
    },
    "entry": { "type": "string", "minLength": 1 },
    "tools": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
        "maxLength": 64
      },
      "description": "Tool name list — underscore format required"
    },
    "config": { "type": "object" },
    "ui": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "slot", "kind", "title"],
        "properties": {
          "id": { "type": "string" },
          "slot": { "enum": ["sidebar"] },
          "kind": { "enum": ["embedded-module", "embedded-page", "info-card"] },
          "displayName": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "defaults": { "type": "object" },
          "entry": { "type": "string" },
          "exportName": { "type": "string" },
          "page": { "type": "string" }
        },
        "allOf": [
          {
            "if": { "properties": { "kind": { "const": "embedded-module" } } },
            "then": { "required": ["id", "slot", "kind", "title", "entry", "exportName"] }
          },
          {
            "if": { "properties": { "kind": { "const": "embedded-page" } } },
            "then": { "required": ["id", "slot", "kind", "title", "page"] }
          },
          {
            "if": { "properties": { "kind": { "const": "info-card" } } },
            "then": { "required": ["id", "slot", "kind", "title"] }
          }
        ]
      }
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["keyword", "skillId"],
        "additionalProperties": false,
        "properties": {
          "keyword": { "type": "string", "minLength": 1 },
          "skillId": { "type": "string", "minLength": 1 }
        }
      }
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "startupTools": {
      "type": "array",
      "items": { "type": "string" }
    },
    "eventSubscriptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "startupTimeoutMs": {
      "type": "integer",
      "minimum": 1,
      "maximum": 60000,
      "description": "Hard startup() timeout (ms). Exceeding plugins are fail-soft dropped. Default slow warning threshold is 5000ms."
    },
    "uiCallable": {
      "type": "array",
      "description": "Method allowlist invokable directly from renderer UI via lvis:plugins:call IPC. Methods not listed must go through ConversationLoop (permission / scope / expansion caps).",
      "items": {
        "type": "string",
        "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
        "maxLength": 64
      }
    },
    "notificationEvents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["event"],
        "additionalProperties": false,
        "properties": {
          "event": { "type": "string", "minLength": 1 },
          "titleField": { "type": "string" },
          "bodyField": { "type": "string" }
        }
      }
    },
    "deployment": { "enum": ["managed", "user"] },
    "publisher": { "type": "string" },
    "toolSchemas": {
      "type": "object",
      "description": "LLM이 메서드를 호출할 때 사용하는 JSON Schema (draft-07). 키: method 이름, 값: { description, inputSchema }",
      "additionalProperties": {
        "type": "object",
        "required": ["description", "inputSchema"],
        "additionalProperties": false,
        "properties": {
          "description": {
            "type": "string",
            "minLength": 10,
            "description": "LLM이 이해할 메서드 설명 (when/what/returns)"
          },
          "inputSchema": {
            "type": "object",
            "required": ["type", "properties"],
            "description": "JSON Schema draft-07 입력 스키마",
            "properties": {
              "$schema": { "type": "string" },
              "type": { "const": "object" },
              "properties": { "type": "object" },
              "required": { "type": "array", "items": { "type": "string" } },
              "additionalProperties": { "type": "boolean" }
            }
          }
        }
      }
    }
  }
}
