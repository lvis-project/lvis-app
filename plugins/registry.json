{
  "version": 1,
  "plugins": [
    {
      "id": "pageindex",
      "manifestPath": "installed/pageindex/plugin.json",
      "enabled": true
    },
    {
      "id": "meeting",
      "manifestPath": "installed/meeting/plugin.json",
      "enabled": true
    },
    {
      "id": "email",
      "manifestPath": "installed/email/plugin.json",
      "enabled": true
    },
    {
      "id": "calendar",
      "manifestPath": "installed/calendar/plugin.json",
      "enabled": true,
      "approvedPluginAccess": {
        "plugins": [
          {
            "pluginId": "email",
            "events": ["email.analyzed", "email.invite.detected"]
          },
          {
            "pluginId": "meeting",
            "events": ["meeting.summary.created"]
          }
        ]
      }
    },
    {
      "id": "lge-api",
      "manifestPath": "installed/lge-api/plugin.json",
      "enabled": true
    },
    {
      "id": "work-proactive",
      "manifestPath": "installed/work-proactive/plugin.json",
      "enabled": true,
      "approvedPluginAccess": {
        "plugins": [
          {
            "pluginId": "calendar",
            "tools": ["calendar_today"],
            "events": ["calendar.event.upcoming", "calendar.event.conflict.detected"]
          },
          {
            "pluginId": "email",
            "events": ["email.new"]
          },
          {
            "pluginId": "meeting",
            "events": ["meeting.summary.created", "meeting.ended"]
          }
        ]
      }
    }
  ]
}
