{
  "id": "pageindex",
  "name": "LVIS PageIndex Plugin",
  "version": "0.1.0",
  "entry": "../../node_modules/@lvis/plugin-pageindex/dist/hostPlugin.js",
  "methods": [
    "index_scan",
    "index_documents",
    "chat_preview"
  ],
  "capabilities": [
    "worker-client",
    "knowledge-index"
  ],
  "ipcBindings": [
    {
      "channel": "lvis:index:scan",
      "method": "index_scan"
    },
    {
      "channel": "lvis:index:documents",
      "method": "index_documents"
    },
    {
      "channel": "lvis:chat:preview",
      "method": "chat_preview",
      "args": ["question"]
    }
  ],
  "config": {
    "scanFolders": ["fixtures"],
    "workspace": ".pageindex-workspace"
  },
  "ui": [
    {
      "id": "pageindex-control",
      "slot": "sidebar",
      "kind": "embedded-module",
      "displayName": "인덱서",
      "title": "PageIndex Indexer",
      "description": "문서 스캔/목록 확인과 채팅창 질문 전송을 제공합니다.",
      "entry": "../../node_modules/@lvis/plugin-pageindex/dist/ui/indexer-control.js"
    }
  ]
}

