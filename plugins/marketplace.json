{
  "version": 1,
  "plugins": [
    {
      "id": "pageindex",
      "slug": "page-indexer",
      "name": "LVIS PageIndex",
      "description": "로컬 문서를 인덱싱하고 질의 미리보기를 제공하는 검색 플러그인",
      "packageSpec": "file:../lvis-plugin-pageindex",
      "packageName": "@lvis/plugin-pageindex",
      "installPolicy": "admin",
      "publisher": "LG Electronics IT",
      "tools": [
        "index_scan",
        "index_documents",
        "chat_preview"
      ],
      "defaultConfig": {
        "scanFolders": [
          "fixtures"
        ],
        "workspace": ".pageindex-workspace"
      },
      "ui": [
        {
          "id": "pageindex-control",
          "slot": "sidebar",
          "kind": "embedded-module",
          "displayName": "인덱서",
          "title": "PageIndex Indexer",
          "description": "문서 스캔/목록 확인과 채팅창 질문 전송을 제공합니다.",
          "entry": "dist/ui/indexer-control.js"
        }
      ]
    },
    {
      "id": "meeting",
      "slug": "meeting-recorder",
      "name": "LVIS Meeting",
      "description": "회의 STT/요약 파이프라인을 제공하는 미팅 플러그인",
      "packageSpec": "file:../lvis-plugin-meeting",
      "packageName": "@lvis/plugin-meeting",
      "installPolicy": "user",
      "publisher": "LG Electronics IT",
      "tools": [
        "meeting_start",
        "meeting_push_chunk",
        "meeting_stop",
        "meeting_transcript"
      ],
      "defaultConfig": {
        "intermediateEveryFinalSegments": 1
      },
      "ui": [
        {
          "id": "meeting-control",
          "slot": "sidebar",
          "kind": "embedded-module",
          "displayName": "미팅",
          "title": "Meeting Recorder",
          "description": "회의 세션 시작/청크 주입/종료/전사 조회를 테스트합니다.",
          "entry": "dist/ui/meeting-control.js"
        }
      ]
    },
    {
      "id": "email",
      "slug": "email-assistant",
      "name": "LVIS Email",
      "description": "Outlook 메일을 읽고 LVIS가 답장·할 일·일정을 제안하는 이메일 플러그인",
      "packageSpec": "file:../lvis-plugin-email",
      "packageName": "@lvis/plugin-email",
      "installPolicy": "user",
      "publisher": "LG Electronics IT",
      "tools": [
        "email_status",
        "email_auth",
        "email_list",
        "email_read",
        "email_analyze"
      ],
      "defaultConfig": {},
      "ui": [
        {
          "id": "email-control",
          "slot": "sidebar",
          "kind": "embedded-module",
          "displayName": "이메일",
          "title": "Outlook Email",
          "description": "Outlook 메일을 읽고 LVIS가 할 일·답장·일정 등을 제안합니다.",
          "entry": "dist/ui/email-control.js"
        }
      ]
    },
    {
      "id": "calendar",
      "slug": "calendar-briefing",
      "name": "LVIS Calendar",
      "description": "Outlook 일정을 읽고 쓰며 미팅 시작 전 알림을 제공하는 캘린더 플러그인",
      "packageSpec": "file:../lvis-plugin-calendar",
      "packageName": "@lvis/plugin-calendar",
      "installPolicy": "user",
      "publisher": "LG Electronics IT",
      "tools": [
        "calendar_status",
        "calendar_auth",
        "calendar_list",
        "calendar_today",
        "calendar_get",
        "calendar_create",
        "calendar_update",
        "calendar_delete",
        "calendar_start_watcher",
        "calendar_stop_watcher",
        "calendar_open_url",
        "calendar_detect_patterns"
      ],
      "pluginAccess": {
        "plugins": [
          {
            "pluginId": "email",
            "events": [
              "email.analyzed",
              "email.invite.detected"
            ]
          },
          {
            "pluginId": "meeting",
            "events": [
              "meeting.summary.created"
            ]
          }
        ]
      },
      "defaultConfig": {},
      "ui": [
        {
          "id": "calendar-control",
          "slot": "sidebar",
          "kind": "embedded-module",
          "displayName": "캘린더",
          "title": "Outlook Calendar",
          "description": "Outlook 일정을 읽고 쓰며 미팅 시작 전 알림을 제공합니다.",
          "entry": "dist/ui/calendar-control.js"
        }
      ]
    },
    {
      "id": "lge-api",
      "name": "LVIS EP",
      "description": "EP 사내 포털 SSO 로그인 + 시설 예약 조회 + Tool 시험대",
      "packageSpec": "file:../lvis-plugin-lge-api",
      "packageName": "@lvis/plugin-lge-api",
      "installPolicy": "admin",
      "publisher": "LG Electronics IT",
      "tools": [
        "lge_login",
        "lge_status",
        "lge_facility_list"
      ],
      "defaultConfig": {},
      "ui": [
        {
          "id": "lge-control",
          "slot": "sidebar",
          "kind": "embedded-module",
          "displayName": "EP",
          "title": "EP",
          "description": "EP 로그인 + 시설 예약 조회 + Tool 시험대.",
          "entry": "dist/ui/lge-control.js",
          "exportName": "mount"
        }
      ]
    },
    {
      "id": "work-proactive",
      "slug": "work-proactive",
      "name": "LVIS Work Proactive",
      "description": "Routine이 호출하는 메일/캘린더/미팅 번들 proactive 플러그인",
      "packageSpec": "file:../lvis-plugin-work-proactive",
      "packageName": "@lvis/plugin-work-proactive",
      "installPolicy": "user",
      "bundleDependencies": [
        {
          "pluginId": "calendar",
          "required": true
        },
        {
          "pluginId": "email",
          "required": true
        },
        {
          "pluginId": "meeting",
          "required": true
        }
      ],
      "pluginAccess": {
        "plugins": [
          {
            "pluginId": "calendar",
            "tools": [
              "calendar_today"
            ]
          },
          {
            "pluginId": "email",
            "events": [
              "email.action.needed"
            ]
          },
          {
            "pluginId": "meeting",
            "events": [
              "meeting.summary.created",
              "meeting.ended"
            ]
          }
        ]
      },
      "requires": {
        "capabilities": [
          "calendar-source"
        ]
      },
      "publisher": "LG Electronics IT",
      "tools": [
        "work_proactive_generate_daily_briefing"
      ],
      "toolSchemas": {
        "work_proactive_generate_daily_briefing": {
          "description": "오늘 메일/캘린더/미팅 맥락을 바탕으로 데일리 브리핑을 생성하고 lvis:routine:completed 이벤트로 전달합니다.",
          "inputSchema": {
            "type": "object",
            "properties": {
              "trigger": {
                "type": "string"
              },
              "nowIso": {
                "type": "string"
              },
              "prompt": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        }
      }
    }
  ]
}
