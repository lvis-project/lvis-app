{
  "id": "calendar",
  "name": "LVIS Calendar",
  "version": "0.1.0",
  "deployment": "managed",
  "publisher": "LG Electronics IT",
  "entry": "../../../node_modules/@lvis/plugin-calendar/dist/hostPlugin.js",
  "methods": [
    "calendar_status",
    "calendar_auth",
    "calendar_list",
    "calendar_today",
    "calendar_get",
    "calendar_create",
    "calendar_update",
    "calendar_delete",
    "calendar_start_watcher",
    "calendar_stop_watcher",
    "calendar_open_url",
    "calendar_detect_patterns"
  ],
  "capabilities": [
    "calendar-source",
    "background-watcher"
  ],
  "startupMethods": [
    "calendar_start_watcher"
  ],
  "eventSubscriptions": [
    "meeting.ended",
    "email.action.needed"
  ],
  "config": {},
  "ui": [
    {
      "id": "calendar-control",
      "slot": "sidebar",
      "kind": "embedded-module",
      "displayName": "캘린더",
      "title": "Outlook Calendar",
      "description": "Outlook 일정을 읽고 쓰며 미팅 시작 전 알림을 제공합니다.",
      "entry": "../../../node_modules/@lvis/plugin-calendar/dist/ui/calendar-control.js"
    }
  ]
}
