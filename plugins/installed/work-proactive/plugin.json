{
  "id": "work-proactive",
  "name": "LVIS Work Proactive",
  "version": "1.0.0",
  "installPolicy": "user",
  "dependencies": [
    {
      "pluginId": "calendar",
      "required": true
    },
    {
      "pluginId": "email",
      "required": true
    },
    {
      "pluginId": "meeting",
      "required": true
    }
  ],
  "pluginAccess": {
    "plugins": [
      {
        "pluginId": "calendar",
        "tools": [
          "calendar_today"
        ],
        "events": [
          "calendar.event.upcoming",
          "calendar.event.conflict.detected"
        ]
      },
      {
        "pluginId": "email",
        "events": [
          "email.action.needed"
        ]
      },
      {
        "pluginId": "meeting",
        "events": [
          "meeting.summary.created",
          "meeting.ended"
        ]
      }
    ]
  },
  "publisher": "LG Electronics IT",
  "entry": "../../../node_modules/@lvis/plugin-work-proactive/dist/hostPlugin.js",
  "description": "메일 액션, 오늘 일정, 회의 요약/종료 이벤트를 모아 LVIS 루틴용 업무 브리핑과 종료 요약을 생성하는 proactive 오케스트레이터 플러그인",
  "tools": [
    "work_proactive_generate_daily_briefing"
  ],
  "capabilities": [
    "conversation-trigger"
  ],
  "requires": {
    "capabilities": [
      "calendar-source"
    ]
  },
  "eventSubscriptions": [
    "email.action.needed",
    "meeting.summary.created",
    "meeting.ended",
    "calendar.event.upcoming",
    "calendar.event.conflict.detected"
  ],
  "emittedEvents": [],
  "toolSchemas": {
    "work_proactive_generate_daily_briefing": {
      "description": "메일 액션 필요 이벤트, 오늘 캘린더 일정, 최근 회의 요약/종료 이벤트를 모아 루틴 결과용 업무 브리핑을 생성합니다. 사용 시기: 호스트 루틴이 wakeup, schedule, shutdown 트리거로 하루 시작 브리핑·주기적 업무 pulse·퇴근 요약을 만들 때. 사용 안 함: 사용자가 단일 메일/일정/회의 원문을 직접 요청하면 email_*, calendar_*, meeting_* 도구를 우선 호출하세요. 반환: { generatedAt, trigger, items[{category, priority, title, detail?}], summary }. LLM 호출 실패 시에도 수집된 항목 기반 fallback summary를 반환합니다.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "trigger": {
            "type": "string",
            "enum": [
              "wakeup",
              "schedule",
              "shutdown"
            ],
            "description": "브리핑 생성 맥락. wakeup은 하루 시작 브리핑, schedule은 주기적 업무 pulse, shutdown은 퇴근/종료 요약입니다."
          },
          "nowIso": {
            "type": "string",
            "format": "date-time",
            "description": "브리핑 기준 시각(ISO 8601). 생략하면 현재 시각을 사용합니다."
          },
          "prompt": {
            "type": "string",
            "description": "기본 브리핑 지시문을 대체할 선택 프롬프트. 운영 루틴별 말투/길이를 조정할 때만 사용하세요."
          }
        },
        "additionalProperties": false
      }
    }
  }
}
