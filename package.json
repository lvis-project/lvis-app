{
  "name": "lvis-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Test Electron host app for LVIS plugins.",
  "main": "dist/src/main.js",
  "scripts": {
    "postinstall": "electron-rebuild && node scripts/fetch-uv.mjs",
    "prepare:plugins": "bun run --cwd ../lvis-plugin-pageindex build && bun run --cwd ../lvis-plugin-meeting build && bun run --cwd ../lvis-plugin-email build && bun run --cwd ../lvis-plugin-calendar build",
    "prepare:plugins:npm": "npm run --prefix ../lvis-plugin-pageindex build && npm run --prefix ../lvis-plugin-meeting build && npm run --prefix ../lvis-plugin-email build && npm run --prefix ../lvis-plugin-calendar build",
    "build:main": "tsc -p tsconfig.json",
    "build:renderer": "esbuild src/renderer.tsx --bundle --platform=browser --format=esm --outfile=dist/src/renderer.js",
    "build:styles": "tailwindcss -i src/styles.css -o dist/src/styles.css --minify",
    "build:preload": "esbuild src/preload.ts --bundle --platform=node --format=cjs --external:electron --outfile=dist/src/preload.js",
    "build": "bun run build:main && bun run build:renderer && bun run build:styles && bun run build:preload && node scripts/copy-build-assets.mjs src/index.html dist/src/index.html && node scripts/check-no-tls-bypass.mjs",
    "build:npm": "npm run build:main && npm run build:renderer && npm run build:styles && npm run build:preload && node scripts/copy-build-assets.mjs src/index.html dist/src/index.html && node scripts/check-no-tls-bypass.mjs",
    "typecheck": "tsc --noEmit",
    "start": "bun run prepare:plugins && bun run build && node scripts/run-electron.mjs dist/src/main.js",
    "start:npm": "npm run prepare:plugins:npm && npm run build:npm && node scripts/run-electron.mjs dist/src/main.js",
    "plugins:list": "tsx scripts/plugins-cli.ts list",
    "plugins:install": "tsx scripts/plugins-cli.ts install",
    "plugins:add": "tsx scripts/plugins-cli.ts add",
    "plugins:remove": "tsx scripts/plugins-cli.ts remove",
    "plugins:enable": "tsx scripts/plugins-cli.ts enable",
    "plugins:disable": "tsx scripts/plugins-cli.ts disable",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:electron-smoke": "node scripts/run-electron.mjs --version",
    "test:plugin-flow": "tsx scripts/test-pageindex-flow.ts",
    "test:meeting-flow": "bun run prepare:plugins && tsx scripts/test-meeting-flow.ts",
    "test:meeting-flow:npm": "npm run prepare:plugins:npm && tsx scripts/test-meeting-flow.ts",
    "test:main-flow": "bun run prepare:plugins && tsx scripts/test-main-flow.ts",
    "test:main-flow:npm": "npm run prepare:plugins:npm && tsx scripts/test-main-flow.ts",
    "sign:manifest": "node scripts/sign-manifest.mjs",
    "keygen:publisher": "node scripts/keygen-publisher.mjs",
    "release": "node scripts/release.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "~3.0.71",
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/google-vertex": "^4.0.112",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/openai-compatible": "~2.0.41",
    "@anthropic-ai/sdk": "^0.88.0",
    "@azure/msal-node": "^5.1.2",
    "@google/generative-ai": "^0.24.1",
    "@lvis/plugin-calendar": "file:../lvis-plugin-calendar",
    "@lvis/plugin-email": "file:../lvis-plugin-email",
    "@lvis/plugin-meeting": "file:../lvis-plugin-meeting",
    "@lvis/plugin-pageindex": "file:../lvis-plugin-pageindex",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "ai": "~6.0.168",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "electron-updater": "~6.8.3",
    "lucide-react": "^1.7.0",
    "openai": "^6.34.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "undici": "^8.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ai-sdk/devtools": "^0.0.15",
    "@electron/rebuild": "^4.0.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "electron": "^41.2.0",
    "esbuild": "^0.28.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  },
  "trustedDependencies": [
    "better-sqlite3",
    "electron",
    "esbuild"
  ],
  "build": {
    "appId": "com.lge.lvis",
    "productName": "LVIS",
    "publish": [
      {
        "provider": "github",
        "owner": "lvis-project",
        "repo": "lvis-app"
      }
    ],
    "extraResources": [
      {
        "from": "resources/uv/${os}${arch}",
        "to": "uv"
      },
      {
        "from": "../lvis-plugin-pageindex/python-requirements.lock",
        "to": "python-requirements.lock"
      }
    ],
    "mac": {
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    }
  }
}
