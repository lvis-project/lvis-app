{
  "name": "lvis-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Test Electron host app for LVIS plugins.",
  "author": {
    "name": "lvis-project",
    "email": "jo.dreame@gmail.com"
  },
  "main": "dist/src/main.js",
  "scripts": {
    "postinstall": "electron-rebuild && node scripts/fetch-uv.mjs && node scripts/register-lvis-protocol.mjs",
    "build:main": "tsc -p tsconfig.json",
    "build:webpack": "webpack --config webpack.config.cjs",
    "build:renderer": "webpack --config webpack.config.cjs --config-name renderer",
    "build:styles": "tailwindcss -i src/styles.css -o dist/src/styles.css --minify",
    "build:preload": "webpack --config webpack.config.cjs --config-name preload",
    "build:plugin-preload": "webpack --config webpack.config.cjs --config-name pluginPreload",
    "build": "bun run build:main && bun run build:webpack && bun run build:styles && node scripts/copy-build-assets.mjs src/index.html dist/src/index.html src/plugin-ui-shell.html dist/src/plugin-ui-shell.html src/plugin-ui-shell.js dist/src/plugin-ui-shell.js scripts/electron-flags.mjs dist/scripts/electron-flags.mjs && node scripts/check-no-tls-bypass.mjs",
    "typecheck": "tsc --noEmit",
    "start": "bun run build && node scripts/run-electron.mjs dist/src/main.js",
    "dev": "node scripts/run-electron-dev.mjs",
    "plugins:list": "tsx scripts/plugins-cli.ts list",
    "plugins:add": "tsx scripts/plugins-cli.ts add",
    "plugins:remove": "tsx scripts/plugins-cli.ts remove",
    "plugins:enable": "tsx scripts/plugins-cli.ts enable",
    "plugins:disable": "tsx scripts/plugins-cli.ts disable",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui-e2e": "playwright test",
    "test:electron-smoke": "node scripts/run-electron.mjs --version",
    "test:main-flow": "tsx scripts/test-main-flow.ts",
    "dist": "node scripts/build-installers.mjs --current",
    "dist:current": "node scripts/build-installers.mjs --current",
    "dist:mac": "node scripts/build-installers.mjs --mac",
    "dist:linux": "node scripts/build-installers.mjs --linux",
    "dist:win": "node scripts/build-installers.mjs --win",
    "release": "node scripts/release.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "~3.0.71",
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/google-vertex": "^4.0.112",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/openai-compatible": "~2.0.41",
    "@azure/msal-node": "^5.1.2",
    "@lvis/plugin-sdk": "github:lvis-project/lvis-plugin-sdk#v4.3.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "ai": "~6.0.168",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "baseline-browser-mapping": "^2.10.27",
    "better-sqlite3": "^12.8.0",
    "caniuse-lite": "^1.0.30001792",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "electron-updater": "~6.8.3",
    "eruda": "^3.4.3",
    "lucide-react": "^1.7.0",
    "pino": "^9",
    "proper-lockfile": "^4.1.2",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "undici": "^8.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ai-sdk/devtools": "^0.0.15",
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.48.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react": "^10.3.6",
    "@storybook/react-vite": "^8.6.14",
    "@storybook/test": "^8.6.14",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "adm-zip": "^0.5.16",
    "autoprefixer": "^10.4.27",
    "electron": "^41.2.0",
    "electron-builder": "26.9.0",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.2",
    "pino-pretty": "^13",
    "playwright": "^1.48.0",
    "postcss": "^8.5.9",
    "storybook": "^8.6.14",
    "tailwindcss": "^3.4.13",
    "ts-loader": "^9.5.2",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "vite": "^8.0.8",
    "vitest": "^2.1.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^6.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  },
  "trustedDependencies": [
    "better-sqlite3",
    "electron",
    "esbuild"
  ],
  "build": {
    "appId": "com.lge.lvis",
    "productName": "LVIS",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release"
    },
    "protocols": [
      {
        "name": "LVIS URL",
        "schemes": [
          "lvis"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "lvis-project",
        "repo": "lvis-app"
      }
    ],
    "extraResources": [
      {
        "from": "resources/uv",
        "to": "uv"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "linux": {
      "category": "Office",
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ]
    },
    "appImage": {
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    },
    "deb": {
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    },
    "rpm": {
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "${productName}-${version}-windows-${arch}-setup.${ext}"
    }
  }
}
