{
  "name": "lvis-app",
  "version": "0.4.4",
  "private": true,
  "type": "module",
  "imports": {
    "#components/*": "./src/components/*.tsx",
    "#hooks/*": "./src/hooks/*.ts",
    "#lib/*": "./src/lib/*.ts"
  },
  "description": "Test Electron host app for LVIS plugins.",
  "homepage": "https://github.com/lvis-project/lvis-app",
  "author": {
    "name": "Ken Jo",
    "email": "jo.dreame@gmail.com"
  },
  "engines": {
    "node": ">=22.4"
  },
  "main": "dist/src/main/main.js",
  "scripts": {
    "postinstall": "electron-rebuild --only better-sqlite3 && node scripts/fetch-uv.mjs && node scripts/register-lvis-protocol.mjs",
    "build:main": "node scripts/build-main-esbuild.mjs",
    "build:webpack": "webpack --config webpack.config.cjs",
    "build:renderer": "webpack --config webpack.config.cjs --config-name renderer",
    "build:styles": "tailwindcss --input src/styles.css --output dist/src/styles.css --minify",
    "build:preload": "webpack --config webpack.config.cjs --config-name preload",
    "build:plugin-preload": "webpack --config webpack.config.cjs --config-name pluginPreload",
    "build:icons": "node scripts/generate-lvis-icons.cjs",
    "build": "bun run check:sunset-inventory && node scripts/clean-dist.mjs && bun run build:icons && bun run build:main && bun run check:i18n-catalog && bun run build:webpack && bun run build:styles && node scripts/copy-build-assets.mjs && node scripts/check-no-tls-bypass.mjs && node scripts/check-opacity-tokens.mjs && node scripts/check-color-tokens.mjs",
    "typecheck": "tsc --noEmit",
    "start": "bun run build && node scripts/run-electron.mjs dist/src/main/main.js",
    "dev": "node scripts/run-electron-dev.mjs",
    "plugins:list": "tsx scripts/plugins-cli.ts list",
    "plugins:add": "tsx scripts/plugins-cli.ts add",
    "plugins:remove": "tsx scripts/plugins-cli.ts remove",
    "plugins:enable": "tsx scripts/plugins-cli.ts enable",
    "plugins:disable": "tsx scripts/plugins-cli.ts disable",
    "test": "vitest run",
    "check:i18n-catalog": "tsx scripts/i18n-validate-catalog.ts",
    "check:sunset-inventory": "node scripts/check-sunset-inventory.mjs",
    "check:knip": "bunx knip --config knip.jsonc --reporter compact",
    "check:test-duplicates": "node scripts/check-test-duplicates.mjs",
    "test:coverage": "vitest run --coverage",
    "check:test-coverage": "node scripts/run-test-coverage-gate.mjs",
    "check:test-quality": "bun run check:test-duplicates -- --fail-on-duplicates && bun run check:test-coverage",
    "test:watch": "vitest",
    "test:ui-e2e": "playwright test",
    "test:electron-smoke": "node scripts/run-electron.mjs --version",
    "test:packaged-smoke": "node scripts/smoke-packaged-app.mjs --target current",
    "test:main-flow": "tsx scripts/test-main-flow.ts",
    "dist": "node scripts/build-installers.mjs --current",
    "dist:current": "node scripts/build-installers.mjs --current",
    "dist:mac": "node scripts/build-installers.mjs --mac",
    "dist:linux": "node scripts/build-installers.mjs --linux",
    "dist:win": "node scripts/build-installers.mjs --win",
    "dist:fast": "node scripts/build-installers.mjs --current --fast",
    "dist:mac:fast": "node scripts/build-installers.mjs --mac --fast",
    "dist:linux:fast": "node scripts/build-installers.mjs --linux --fast",
    "dist:win:fast": "node scripts/build-installers.mjs --win --fast",
    "release": "node scripts/release.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "~4.0.0",
    "@ai-sdk/azure": "^4.0.0",
    "@ai-sdk/google": "^4.0.0",
    "@ai-sdk/google-vertex": "^5.0.0",
    "@ai-sdk/openai": "^4.0.0",
    "@ai-sdk/openai-compatible": "~3.0.0",
    "@anthropic-ai/sandbox-runtime": "0.0.59",
    "@lvis/plugin-sdk": "github:lvis-project/lvis-plugin-sdk#v5.20.0",
    "adm-zip": "^0.5.16",
    "ai": "~7.0.2",
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "better-sqlite3": "^12.11.1",
    "electron-updater": "~6.8.3",
    "pino": "^10",
    "pino-pretty": "^13",
    "proper-lockfile": "^4.1.2",
    "undici": "^8.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ai-sdk/devtools": "^1.0.0",
    "@electron/rebuild": "^4.0.3",
    "@playwright/test": "^1.48.0",
    "@storybook/react": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@tailwindcss/cli": "^4.2.4",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.1",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.6",
    "baseline-browser-mapping": "^2.10.27",
    "caniuse-lite": "^1.0.30001792",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "electron": "^42.4.1",
    "electron-builder": "26.15.3",
    "eruda": "^3.4.3",
    "esbuild": "^0.28.0",
    "jsdom": "^29.0.2",
    "lucide-react": "^1.7.0",
    "playwright": "^1.48.0",
    "postcss": "^8.5.9",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-day-picker": "^10.0.0",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.7.0",
    "storybook": "^10.3.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "ts-loader": "^9.5.2",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.6",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild"
    ]
  },
  "trustedDependencies": [
    "better-sqlite3",
    "electron",
    "esbuild"
  ],
  "build": {
    "appId": "xyz.lvisai.app",
    "productName": "LVIS",
    "icon": "build/icon.png",
    "electronLanguages": [
      "en-US",
      "ko",
      "ja",
      "zh-CN",
      "es",
      "fr",
      "de"
    ],
    "afterPack": "scripts/electron-after-pack.cjs",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json",
      "!dist/src/components{,/**/*}",
      "!dist/src/ui{,/**/*}",
      "!dist/**/{__tests__,__probes__,test,tests,fixtures}{,/**/*}",
      "!dist/**/*.{test,spec}.{js,cjs,mjs}",
      "!dist/scripts/**/*.js",
      "!node_modules/*/{docs,doc,test,tests,__tests__,example,examples,benchmark,benchmarks,coverage}{,/**/*}",
      "!node_modules/@*/*/{docs,doc,test,tests,__tests__,example,examples,benchmark,benchmarks,coverage}{,/**/*}",
      "!node_modules/**/{browser-test,system-test,*-test,test-*}{,/**/*}",
      "!node_modules/better-sqlite3/deps{,/**/*}",
      "!node_modules/better-sqlite3/src{,/**/*}",
      "!node_modules/better-sqlite3/binding.gyp",
      "!node_modules/{prebuild-install,napi-build-utils,node-abi}{,/**/*}",
      "!node_modules/{ai,zod,undici,adm-zip,proper-lockfile}{,/**/*}",
      "!node_modules/@ai-sdk{,/**/*}",
      "!node_modules/@azure/msal-*{,/**/*}",
      "!node_modules/@radix-ui{,/**/*}",
      "!node_modules/{class-variance-authority,clsx,cmdk,date-fns,eruda,lucide-react,radix-ui,react,react-day-picker,react-dom,react-markdown,remark-gfm,shadcn,tailwind-merge,tw-animate-css}{,/**/*}",
      "!node_modules/**/*.{test,spec}.{js,cjs,mjs}",
      "!node_modules/**/{.github,.vscode,.idea}{,/**/*}",
      "!node_modules/**/*.{map,ts,tsx,mts,cts,md,markdown}",
      "!node_modules/**/tsconfig*.json",
      "!resources/uv{,/**/*}",
      "!resources/uv-runtime{,/**/*}"
    ],
    "asarUnpack": [
      "node_modules/@anthropic-ai/sandbox-runtime/vendor/**"
    ],
    "directories": {
      "output": "release"
    },
    "protocols": [
      {
        "name": "LVIS URL",
        "schemes": [
          "lvis"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "lvis-project",
        "repo": "lvis-app"
      }
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "build/tray-icon.png",
        "to": "tray-icon.png"
      },
      {
        "from": "build/tray-icon@2x.png",
        "to": "tray-icon@2x.png"
      },
      {
        "from": "build/tray-iconTemplate.png",
        "to": "tray-iconTemplate.png"
      },
      {
        "from": "build/tray-iconTemplate@2x.png",
        "to": "tray-iconTemplate@2x.png"
      },
      {
        "from": "resources/uv-runtime",
        "to": "uv"
      },
      {
        "from": "resources/licenses/uv",
        "to": "licenses/uv"
      },
      {
        "from": "resources/AGENTS.md",
        "to": "AGENTS.md"
      },
      {
        "from": "resources/agents",
        "to": "agents",
        "filter": [
          "*.md"
        ]
      },
      {
        "from": "resources/skills",
        "to": "skills",
        "filter": [
          "*.md"
        ]
      },
      {
        "from": "resources/prompts",
        "to": "prompts",
        "filter": [
          "*.md"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
      "window": {
        "width": 540,
        "height": 420
      },
      "contents": [
        {
          "x": 140,
          "y": 130,
          "type": "file"
        },
        {
          "x": 400,
          "y": 130,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 140,
          "y": 290,
          "type": "file",
          "path": "build/dmg-extras/setup.command"
        },
        {
          "x": 270,
          "y": 290,
          "type": "file",
          "path": "build/dmg-extras/uninstall.command"
        },
        {
          "x": 400,
          "y": 290,
          "type": "file",
          "path": "build/dmg-extras/README.txt"
        }
      ]
    },
    "linux": {
      "category": "Office",
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ]
    },
    "appImage": {
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    },
    "deb": {
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    },
    "rpm": {
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "runAfterFinish": true,
      "differentialPackage": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": true,
      "include": "build/installer.nsh",
      "uninstallDisplayName": "LVIS",
      "shortcutName": "LVIS",
      "artifactName": "${productName}-${version}-windows-${arch}-setup.${ext}"
    }
  }
}
